apiVersion: v1
kind: Service
metadata:
  labels:
    app: {{ hcp.control_plane.clusters_namespace }}
  name: {{ hcp.control_plane.hosted_cluster_name }}-apps
  namespace: {{ hosted_control_plane_namespace }}

spec:
  ports:
    - name: https-443
      port: 443
      protocol: TCP
      targetPort: {{ https_nodeport }}

    - name: http-80
      port: 80
      protocol: TCP
      targetPort: {{ http_nodeport }}

  selector:
    kubevirt.io: virt-launcher

  type: LoadBalancer
