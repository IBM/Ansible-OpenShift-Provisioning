apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: odf-operator
  namespace: "{{ (hcp.odf | default({})).namespace | default('openshift-storage', true) }}"
spec:
  sourceNamespace: openshift-marketplace
  source: redhat-operators
{% if (hcp.odf | default({})).version | default('', true) | length > 0 %}
  channel: "{{ (hcp.odf | default({})).version }}"
{% endif %}
  installPlanApproval: Automatic
  name: odf-operator
